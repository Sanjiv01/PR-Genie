GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# vLLM endpoint — point at your Brev GPU instance.
# Local default matches the team's `99_baseline_only.sh` / `04_serve_optimized.sh` (port 5000).
# For Brev, replace localhost with the public IP from `brev open` or the tunnel URL:
#   VLLM_BASE_URL=http://<brev-ip>:5000/v1
VLLM_BASE_URL=http://localhost:5000/v1
# served-model-name from the vllm serve command, NOT the HF id.
VLLM_MODEL=nemotron
# nvext steerability tag — flips on the Track 5 priority/OSL headers
ENABLE_NVEXT_HEADERS=true
# Set to false once Brev endpoint is live; true uses backend/llm/mock_responses.py
MOCK_MODE=true
DATABASE_URL=sqlite:///./prdemo.db
PORT=8080
